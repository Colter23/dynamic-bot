{
  "schemaVersion": 2,
  "plugins": [
    {
      "id": "bilibili-publisher",
      "name": "Bilibili 动态源插件",
      "description": "检测 Bilibili 动态、开播和下播事件，支持发布者查询、登录状态和订阅联动。",
      "release": {
        "provider": "GITHUB_RELEASE",
        "repository": "Colter23/dynamic-bot-bilibili",
        "assetPattern": "dynamic-bot-bilibili-*-all.jar",
        "checksumAssetPattern": "dynamic-bot-bilibili-*-all.jar.sha256"
      },
      "homepageUrl": "https://github.com/Colter23/dynamic-bot-bilibili",
      "capabilities": [
        "PUBLISHER_SOURCE",
        "PUBLISHER_LOOKUP",
        "PUBLISHER_FOLLOW",
        "PUBLISHER_LOGIN",
        "CONFIGURABLE"
      ]
    },
    {
      "id": "onebot-gateway",
      "name": "OneBot 网关插件",
      "description": "通过正向或反向 WebSocket 连接 OneBot，实现消息投递和命令接收。",
      "release": {
        "provider": "GITHUB_RELEASE",
        "repository": "Colter23/dynamic-bot-onebot",
        "assetPattern": "dynamic-bot-onebot-*-all.jar",
        "checksumAssetPattern": "dynamic-bot-onebot-*-all.jar.sha256"
      },
      "homepageUrl": "https://github.com/Colter23/dynamic-bot-onebot",
      "capabilities": [
        "MESSAGE_SINK",
        "COMMAND_CONTRIBUTOR",
        "CONFIGURABLE"
      ]
    }
  ]
}
